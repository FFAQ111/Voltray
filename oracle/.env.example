# Private key of the event's utility address — the oracle signs settle() as the utility.
# For the MVP the oracle holds the key directly; post-MVP this becomes oracle-signature
# verification or a multisig (see contracts/sources/voltray.move settle()).
#
# Export it with:
#   sui keytool export --key-identity <utility-address>
# then copy the "suiprivkey1..." value below.
ORACLE_SECRET_KEY=suiprivkey1...

# Private key of the demo charger that signs session readings. settle() verifies this signature
# against the event's authorised charger_pubkey before paying (docs/TRUST.md §5.1). Generate a
# demo pair with `pnpm gen:charger`; register its public key in web/src/lib/config.ts
# (DEMO_CHARGER_PUBKEY). Kept separate from ORACLE_SECRET_KEY on purpose: the oracle submits the
# tx, the charger signs the kWh.
CHARGER_SECRET_KEY=suiprivkey1...
